 * Description: Blink LED with pot control and serial logging
 */
int count = 0;
void setup() {
  pinMode(13, OUTPUT);
  Serial.begin(9600);
}
void loop() {
  int speed = analogRead(A0);
  digitalWrite(13, HIGH);
  delay(speed);
  digitalWrite(13, LOW);
  delay(speed);
  Serial.print("Blink count: ");
  Serial.println(++count);
}
